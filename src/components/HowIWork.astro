---
const principles = [
  {
    icon: 'cpu',
    title: 'AI as a real collaborator',
    body: 'Not autocomplete. Claude Code and Dify are how I move from spec to working build in one evening. The skill is in the prompt, not the typing.',
  },
  {
    icon: 'message-square',
    title: 'Async-first, written-first',
    body: 'I work in long-form documents and Upwork chat. No video calls if avoidable. Kyoto timezone (UTC+9), but most async-friendly clients won\'t notice.',
  },
  {
    icon: 'rocket',
    title: 'Ship, then refine',
    body: 'MVP in three days, polish in week two. The first version is ugly on purpose — it forces decisions about what actually matters.',
  },
];
---

<section id="process" class="py-24 lg:py-24 py-16">
  <div class="max-w-5xl mx-auto px-6">
    <!-- Section header -->
    <div class="mb-12">
      <p class="font-mono text-[13px] text-ink-muted dark:text-night-muted tracking-[0.15em] uppercase mb-3">
        PROCESS · <span class="font-jp">流儀</span>
      </p>
      <h2
        class="font-sans font-bold text-ink dark:text-night-text tracking-[-0.02em] mb-2"
        style="font-size: 28px;"
      >
        How I work
      </h2>
      <p class="text-base text-ink-muted dark:text-night-muted">
        Three operating principles.
      </p>
    </div>

    <!-- Principle cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {principles.map((p) => (
        <div
          class="bg-bg-card dark:bg-night-card rounded-2xl p-6 border border-border dark:border-night-border shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-200"
        >
          <!-- Icon -->
          <div class="w-8 h-8 rounded-lg bg-vibe-bg dark:bg-vibe/10 flex items-center justify-center mb-5">
            {p.icon === 'cpu' && (
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#7C3AED" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="4" y="4" width="16" height="16" rx="2"/>
                <rect x="9" y="9" width="6" height="6"/>
                <line x1="9" y1="1" x2="9" y2="4"/>
                <line x1="15" y1="1" x2="15" y2="4"/>
                <line x1="9" y1="20" x2="9" y2="23"/>
                <line x1="15" y1="20" x2="15" y2="23"/>
                <line x1="20" y1="9" x2="23" y2="9"/>
                <line x1="20" y1="14" x2="23" y2="14"/>
                <line x1="1" y1="9" x2="4" y2="9"/>
                <line x1="1" y1="14" x2="4" y2="14"/>
              </svg>
            )}
            {p.icon === 'message-square' && (
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#7C3AED" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
              </svg>
            )}
            {p.icon === 'rocket' && (
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#7C3AED" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/>
                <path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/>
                <path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/>
                <path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/>
              </svg>
            )}
          </div>

          <!-- Title -->
          <h3
            class="font-sans font-semibold text-ink dark:text-night-text mb-3 leading-snug"
            style="font-size: 18px;"
          >
            {p.title}
          </h3>

          <!-- Body -->
          <p class="text-sm text-ink-muted dark:text-night-muted leading-relaxed">
            {p.body}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
