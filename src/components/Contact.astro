---
---

<section id="contact" class="py-24 lg:py-24 py-16">
  <div class="max-w-5xl mx-auto px-6">
    <div
      class="rounded-3xl p-12 lg:p-16"
      style="background-color: #0A0A12;"
    >
      <!-- Section label -->
      <p class="font-mono text-[13px] tracking-[0.15em] uppercase mb-6" style="color: #9CA3AF;">
        CONTACT · <span class="font-jp">連絡</span>
      </p>

      <!-- Heading -->
      <h2
        class="font-sans font-bold tracking-[-0.025em] mb-4"
        style="font-size: 40px; color: #F5F5F7;"
      >
        Let's build something.
      </h2>

      <!-- Subtitle -->
      <p
        class="text-base leading-relaxed max-w-[60ch] mb-10"
        style="color: #9CA3AF;"
      >
        I'm taking on freelance projects through Upwork. Best for: AI-integrated MVPs, Bubble.io backends, Figma dashboards. Reach out and tell me what you're building.
      </p>

      <!-- Button row -->
      <div class="flex flex-wrap gap-3 mb-10">
        <!-- TODO: Shusei to insert Upwork profile URL in place of '#' -->
        <a
          href="#"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center px-6 py-3 rounded-full font-semibold text-sm transition-all duration-200 hover:scale-[1.02]"
          style="background-color: #F5F5F7; color: #0A0A12;"
        >
          Hire me on Upwork →
        </a>

        <!-- TODO: Shusei to insert email address in place of '#' (use mailto:youremail@example.com) -->
        <a
          href="#"
          class="inline-flex items-center px-6 py-3 rounded-full font-medium text-sm border transition-all duration-200 hover:bg-white/10"
          style="border-color: #252535; color: #F5F5F7;"
        >
          Email →
        </a>

        <!-- TODO: Shusei to insert X/Twitter profile URL in place of '#' -->
        <a
          href="#"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center px-6 py-3 rounded-full font-medium text-sm border transition-all duration-200 hover:bg-white/10"
          style="border-color: #252535; color: #F5F5F7;"
        >
          X / Twitter →
        </a>

        <!-- TODO: Shusei to insert GitHub profile URL in place of '#' -->
        <a
          href="#"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center px-6 py-3 rounded-full font-medium text-sm border transition-all duration-200 hover:bg-white/10"
          style="border-color: #252535; color: #F5F5F7;"
        >
          GitHub →
        </a>
      </div>

      <!-- Response time note -->
      <p class="font-mono text-[13px]" style="color: #9CA3AF;">
        Response time: usually within 24h. Async-first, text-based.
      </p>
    </div>
  </div>
</section>
