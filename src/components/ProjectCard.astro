---
interface Props {
  gradient: string;
  heroLabel: string;
  heroSub: string;
  imageSrc: string;
  imageAlt: string;
  tag: string;
  title: string;
  description: string;
  stack: string;
  liveUrl: string;
  caseStudyUrl: string;
  liveLabel?: string;
}

const {
  gradient,
  heroLabel,
  heroSub,
  imageSrc,
  imageAlt,
  tag,
  title,
  description,
  stack,
  liveUrl,
  caseStudyUrl,
  liveLabel = 'View live →',
} = Astro.props;
---

<article
  class="rounded-3xl border border-border dark:border-night-border overflow-hidden bg-bg-card dark:bg-night-card shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-200"
>
  <!-- Visual area -->
  <div
    class="relative flex items-end justify-between p-8 min-h-[220px]"
    style={`background: ${gradient};`}
  >
    <!-- Left text overlay -->
    <div class="flex flex-col gap-1 z-10">
      <span
        class="font-mono font-extrabold text-white leading-none"
        style="font-size: clamp(48px, 6vw, 80px); opacity: 0.95;"
        aria-hidden="true"
      >
        {heroLabel}
      </span>
      <span
        class="font-mono text-[13px] text-white/70 leading-snug max-w-[30ch]"
      >
        {heroSub}
      </span>
    </div>

    <!-- Right: screenshot placeholder -->
    <div
      class="hidden sm:flex flex-shrink-0 w-[180px] h-[112px] rounded-xl border border-white/20 overflow-hidden bg-white/10 backdrop-blur-sm items-center justify-center"
    >
      <img
        src={imageSrc}
        alt={imageAlt}
        class="w-full h-full object-cover"
        loading="lazy"
        width="180"
        height="112"
        onerror="this.style.display='none'; this.parentElement.querySelector('.img-placeholder').style.display='flex';"
      />
      <span class="img-placeholder hidden w-full h-full items-center justify-center">
        <span class="font-mono text-[10px] text-white/40 text-center px-2">
          Replace with<br />screenshot
        </span>
      </span>
    </div>
  </div>

  <!-- Card body -->
  <div class="p-8">
    <!-- Tag -->
    <span
      class="inline-block font-mono text-[11px] text-vibe dark:text-night-glow bg-vibe-bg dark:bg-vibe/10 rounded-full px-3 py-1 uppercase tracking-widest mb-4"
    >
      {tag}
    </span>

    <!-- Title -->
    <h3
      class="font-sans font-bold text-ink dark:text-night-text tracking-[-0.02em] mb-3"
      style="font-size: 22px;"
    >
      {title}
    </h3>

    <!-- Description -->
    <p class="text-base text-ink-muted dark:text-night-muted leading-relaxed mb-6 max-w-[65ch]">
      {description}
    </p>

    <hr class="border-border dark:border-night-border mb-6" />

    <!-- Stack -->
    <p class="font-mono text-[13px] text-ink-soft dark:text-night-muted mb-6">
      {stack}
    </p>

    <!-- Buttons -->
    <div class="flex flex-wrap gap-3">
      <!-- TODO: Shusei to insert live project URL in place of '#' below -->
      <a
        href={liveUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center px-5 py-2.5 rounded-full bg-ink dark:bg-night-text text-bg dark:text-night-bg text-sm font-semibold hover:bg-ink/80 dark:hover:bg-night-text/80 transition-all duration-200"
      >
        {liveLabel}
      </a>
      <!-- TODO: Shusei to insert case study URL in place of '#' below -->
      <a
        href={caseStudyUrl}
        class="inline-flex items-center px-5 py-2.5 rounded-full border border-border dark:border-night-border text-ink-muted dark:text-night-muted text-sm font-medium hover:border-ink dark:hover:border-night-text hover:text-ink dark:hover:text-night-text transition-all duration-200"
      >
        Read case study →
      </a>
    </div>
  </div>
</article>
