---
const stats = [
  {
    number: '5+',
    label: 'Bubble apps shipped',
    icon: 'box',
  },
  {
    number: '14',
    label: 'Screens designed in 4 hours',
    icon: 'layout-grid',
  },
  {
    number: '1',
    label: 'Year of solo freelancing',
    icon: 'calendar',
  },
  {
    number: '∞',
    label: 'Claude Code prompts written',
    icon: 'infinity',
  },
];
---

<section class="py-24 lg:py-24 py-16">
  <div class="max-w-5xl mx-auto px-6">
    <!-- Section header -->
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-10">
      <div>
        <p class="font-mono text-[13px] text-ink-muted dark:text-night-muted tracking-[0.15em] uppercase mb-3">
          RECEIPTS
        </p>
        <h2
          class="font-sans font-bold text-ink dark:text-night-text tracking-[-0.02em]"
          style="font-size: 28px;"
        >
          Last 12 months
        </h2>
      </div>
      <p class="text-sm text-ink-muted dark:text-night-muted font-sans pb-1">
        As of May 2026
      </p>
    </div>

    <!-- Stats grid -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
      {stats.map((stat) => (
        <div
          class="bg-bg-card dark:bg-night-card rounded-2xl p-6 border border-border dark:border-night-border shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-200"
        >
          <!-- Icon -->
          <div class="w-8 h-8 rounded-lg bg-vibe-bg dark:bg-vibe/10 flex items-center justify-center mb-4">
            {stat.icon === 'box' && (
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#7C3AED" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
                <line x1="12" y1="22.08" x2="12" y2="12"/>
              </svg>
            )}
            {stat.icon === 'layout-grid' && (
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#7C3AED" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="3" width="7" height="7" rx="1"/>
                <rect x="14" y="3" width="7" height="7" rx="1"/>
                <rect x="3" y="14" width="7" height="7" rx="1"/>
                <rect x="14" y="14" width="7" height="7" rx="1"/>
              </svg>
            )}
            {stat.icon === 'calendar' && (
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#7C3AED" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                <line x1="16" y1="2" x2="16" y2="6"/>
                <line x1="8" y1="2" x2="8" y2="6"/>
                <line x1="3" y1="10" x2="21" y2="10"/>
              </svg>
            )}
            {stat.icon === 'infinity' && (
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#7C3AED" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 12c-2-2.5-4-4-6-4a4 4 0 0 0 0 8c2 0 4-1.5 6-4z"/>
                <path d="M12 12c2 2.5 4 4 6 4a4 4 0 0 0 0-8c-2 0-4 1.5-6 4z"/>
              </svg>
            )}
          </div>

          <!-- Number -->
          <p
            class="font-mono font-bold text-ink dark:text-night-text leading-none mb-2"
            style="font-size: 40px;"
          >
            {stat.number}
          </p>

          <!-- Label -->
          <p class="text-sm text-ink-muted dark:text-night-muted font-sans leading-snug">
            {stat.label}
          </p>
        </div>
      ))}
    </div>

    <!-- Bridge line -->
    <p class="text-sm text-ink-muted dark:text-night-muted font-sans">
      Numbers are honest. Quality of the work is in the next section.
    </p>
  </div>
</section>
