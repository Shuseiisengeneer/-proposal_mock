---
import ProjectCard from './ProjectCard.astro';

const moreWork = [
  {
    tag: 'HOSPITALITY · SAAS',
    title: 'Hotel Reservation Management',
    description: 'End-to-end booking and room management system for a hospitality client. Real-time availability, multi-property support, and automated confirmation flows.',
    stack: 'Bubble.io · Workflow automation · Email integration',
    gradient: 'from-slate-800 to-slate-700',
  },
  {
    tag: 'MARKETPLACE · MATCHING',
    title: 'MA Matching Platform',
    description: 'Two-sided marketplace connecting buyers and sellers for M&A deals. Custom matching logic, due diligence checklists, and secure document exchange.',
    stack: 'Bubble.io · Custom algorithms · Multi-role auth',
    gradient: 'from-violet-900 to-slate-800',
  },
  {
    tag: 'COMMUNITY · SNS',
    title: 'Auto Mechanic SNS',
    description: 'Vertical social network for automotive professionals. Job postings, skill verification, shop discovery, and a feed tuned for the trade.',
    stack: 'Bubble.io · Real-time feeds · Geolocation',
    gradient: 'from-zinc-800 to-zinc-700',
  },
  {
    tag: 'FINANCE · SAAS',
    title: 'Sales Management SaaS',
    description: 'Revenue tracking dashboard with team-level reporting, quota management, and automated weekly summaries. Reduced manual reporting from hours to zero.',
    stack: 'Bubble.io · Data visualization · Role-based access',
    gradient: 'from-emerald-900 to-slate-800',
  },
  {
    tag: 'INFRASTRUCTURE · COMPLIANCE',
    title: 'Elevator Inspection System',
    description: 'Digital inspection log for certified elevator maintenance — replacing paper checklists with a mobile-first system that passes regulatory audit trails.',
    stack: 'Bubble.io · Mobile-responsive · PDF export',
    gradient: 'from-stone-800 to-stone-700',
  },
  {
    tag: 'WEB · BRANDING',
    title: 'Beauty Salon Group Site',
    description: 'Multi-location website for a salon group. Clean design, location finder, online booking integration, and a CMS the staff can actually use.',
    stack: 'Figma · Astro · Tailwind · Booking API',
    gradient: 'from-rose-900 to-slate-800',
  },
];
---

<section id="work" class="py-24 lg:py-24 py-16">
  <div class="max-w-5xl mx-auto px-6">
    <!-- Section header -->
    <div class="mb-12">
      <p class="font-mono text-[13px] text-ink-muted dark:text-night-muted tracking-[0.15em] uppercase mb-3">
        WORK · <span class="font-jp">仕事</span>
      </p>
      <h2
        class="font-sans font-bold text-ink dark:text-night-text tracking-[-0.02em] mb-2"
        style="font-size: 28px;"
      >
        Featured Projects
      </h2>
      <p class="text-base text-ink-muted dark:text-night-muted">
        Selected work. Details withheld where NDA applies.
      </p>
    </div>

    <!-- Featured project cards -->
    <div class="flex flex-col gap-6 mb-16">
      <!-- Project 1: Quanta Redesign -->
      <ProjectCard
        gradient="linear-gradient(135deg, #1B2845 0%, #7C3AED 60%, #DC2626 100%)"
        heroLabel="4 hours"
        heroSub="Sprint redesign · Astro + Tailwind"
        imageSrc="/images/quanta-preview.png"
        imageAlt="Quanta dashboard redesign preview"
        tag="ED-TECH · DASHBOARD"
        title="Quanta — Dashboard Redesign"
        description="An ed-tech platform's dashboard that looked like a 2015 school portal. I shipped a 14-screen redesign in 4 hours with Claude Code and Figma — the kind of speed that's only possible when you treat AI as a real collaborator, not autocomplete."
        stack="Claude Code · Figma · Tailwind · 14 screens"
        liveUrl="#"
        caseStudyUrl="#"
        liveLabel="View live →"
      />

      <!-- Project 2: Twitter Auto-Posting Bot -->
      <ProjectCard
        gradient="linear-gradient(135deg, #0A0A12 0%, #1B2845 50%, #7C3AED 100%)"
        heroLabel="5 backends"
        heroSub="Bubble.io workflow chains · Claude pair-programmed"
        imageSrc="/images/twitter-bot-preview.png"
        imageAlt="Twitter auto-posting bot preview"
        tag="AUTOMATION · BUBBLE"
        title="Twitter Bot — AI-Powered Posting Engine"
        description="A system that takes long-form videos, splits them into segments, and posts a coordinated thread on X — built on Bubble.io with backend workflow chains so dense even I needed Claude as a pair programmer to navigate them. The kind of work AI-native development was made for."
        stack="Bubble.io · Claude Opus · Backend workflows · Conditional logic"
        liveUrl="#"
        caseStudyUrl="#"
        liveLabel="View live →"
      />
    </div>

    <!-- More work grid -->
    <div class="mb-4">
      <h3
        class="font-sans font-semibold text-ink dark:text-night-text tracking-[-0.01em] mb-6"
        style="font-size: 18px;"
      >
        More work
      </h3>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {moreWork.map((project) => (
          <div class="bg-bg-card dark:bg-night-card rounded-2xl border border-border dark:border-night-border p-6 hover:shadow-lg hover:-translate-y-1 transition-all duration-200 flex flex-col gap-4">
            <!-- Color bar -->
            <div class={`w-full h-1.5 rounded-full bg-gradient-to-r ${project.gradient} opacity-60`}></div>

            <!-- Tag -->
            <span class="font-mono text-[11px] text-vibe dark:text-night-glow bg-vibe-bg dark:bg-vibe/10 rounded-full px-3 py-1 uppercase tracking-widest self-start">
              {project.tag}
            </span>

            <!-- Title -->
            <h4 class="font-sans font-semibold text-ink dark:text-night-text leading-snug" style="font-size: 15px;">
              {project.title}
            </h4>

            <!-- Description -->
            <p class="text-sm text-ink-muted dark:text-night-muted leading-relaxed flex-1">
              {project.description}
            </p>

            <!-- Stack -->
            <p class="font-mono text-[12px] text-ink-soft dark:text-night-muted border-t border-border dark:border-night-border pt-4">
              {project.stack}
            </p>
          </div>
        ))}
      </div>
    </div>

    <p class="text-sm text-ink-muted dark:text-night-muted mt-4">
      NDA applies to client names and project details on all entries above.
    </p>
  </div>
</section>
