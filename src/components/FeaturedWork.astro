---
import ProjectCard from './ProjectCard.astro';
---

<section id="work" class="py-24 lg:py-24 py-16">
  <div class="max-w-5xl mx-auto px-6">
    <!-- Section header -->
    <div class="mb-12">
      <p class="font-mono text-[13px] text-ink-muted dark:text-night-muted tracking-[0.15em] uppercase mb-3">
        WORK · <span class="font-jp">仕事</span>
      </p>
      <h2
        class="font-sans font-bold text-ink dark:text-night-text tracking-[-0.02em] mb-2"
        style="font-size: 28px;"
      >
        Featured Projects
      </h2>
      <p class="text-base text-ink-muted dark:text-night-muted">
        Two recent things I'm proud of.
      </p>
    </div>

    <!-- Project cards -->
    <div class="flex flex-col gap-6">
      <!-- Project 1: Quanta Redesign -->
      <ProjectCard
        gradient="linear-gradient(135deg, #1B2845 0%, #7C3AED 60%, #DC2626 100%)"
        heroLabel="4 hours"
        heroSub="Sprint redesign · Astro + Tailwind"
        imageSrc="/images/quanta-preview.png"
        imageAlt="Quanta dashboard redesign preview"
        tag="ED-TECH · DASHBOARD"
        title="Quanta — Dashboard Redesign"
        description="An ed-tech platform's dashboard that looked like a 2015 school portal. I shipped a 14-screen redesign in 4 hours with Claude Code and Figma — the kind of speed that's only possible when you treat AI as a real collaborator, not autocomplete."
        stack="Claude Code · Figma · Tailwind · 14 screens"
        liveUrl="#"
        caseStudyUrl="#"
        liveLabel="View live →"
      />

      <!-- Project 2: Twitter Auto-Posting Bot -->
      <ProjectCard
        gradient="linear-gradient(135deg, #0A0A12 0%, #1B2845 50%, #7C3AED 100%)"
        heroLabel="5 backends"
        heroSub="Bubble.io workflow chains · Claude pair-programmed"
        imageSrc="/images/twitter-bot-preview.png"
        imageAlt="Twitter auto-posting bot preview"
        tag="AUTOMATION · BUBBLE"
        title="Twitter Bot — AI-Powered Posting Engine"
        description="A system that takes long-form videos, splits them into segments, and posts a coordinated thread on X — built on Bubble.io with backend workflow chains so dense even I needed Claude as a pair programmer to navigate them. The kind of work AI-native development was made for."
        stack="Bubble.io · Claude Opus · Backend workflows · Conditional logic"
        liveUrl="#"
        caseStudyUrl="#"
        liveLabel="View live →"
      />
    </div>
  </div>
</section>
